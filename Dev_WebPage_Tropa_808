    <script>
        // --- NAVEGACIÓN ---
        window.switchView = (v) => {
            const menu = document.getElementById('mobile-menu');
            if(menu) menu.classList.remove('active');
            
            const main = document.getElementById('main-view');
            const docs = document.getElementById('docs-view');
            const insignia = document.getElementById('insignia-view');
            
            // Ocultar todas las vistas
            main.classList.add('hidden');
            docs.classList.add('hidden');
            if(insignia) insignia.classList.add('hidden');
            
            // Mostrar la seleccionada y actualizar URL
            if (v === 'docs') { 
                docs.classList.remove('hidden'); 
                try { window.history.pushState(null, null, '#recursos'); } catch(e) {}
            } else if (v === 'insignia') { 
                if(insignia) insignia.classList.remove('hidden'); 
                try { window.history.pushState(null, null, '#insignia'); } catch(e) {}
            } else { 
                main.classList.remove('hidden'); 
                // Limpiar URL si venimos de recursos o insignia para no dejar rastros
                if (window.location.hash === '#recursos' || window.location.hash === '#insignia') {
                    try { window.history.pushState(null, null, window.location.pathname + window.location.search); } catch(e) {}
                }
            }
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        };

        window.scrollToSection = (id) => {
            if (document.getElementById('main-view').classList.contains('hidden')) switchView('main');
            document.getElementById('mobile-menu').classList.remove('active');
            setTimeout(() => {
                const el = document.getElementById(id);
                if (el) window.scrollTo({ top: el.offsetTop - 80, behavior: "smooth" });
            }, 100);
        };

        const mobileBtn = document.getElementById('mobile-btn');
        if(mobileBtn) mobileBtn.onclick = (e) => { 
            e.stopPropagation(); document.getElementById('mobile-menu').classList.toggle('active'); 
        };
        document.addEventListener('click', () => document.getElementById('mobile-menu').classList.remove('active'));

        // --- GALERÍA ---
        const galleryImages = [
            "https://lh3.googleusercontent.com/d/1Ki7G_Ctx5589PBCSPHmpIL9Miz5DYkCo",
            "https://lh3.googleusercontent.com/d/1Rt9i2-rrZrGoqFChKSQCOS9LfiiSSrIg",
            "https://lh3.googleusercontent.com/d/1kYTjnBWYuPNK9d-AGCqIz4G-i-2buw8j",
            "https://lh3.googleusercontent.com/d/1sf4NMBDyT-JkwfzjmGJU6HlEdYRzD9z4"
        ];
        let currentPhotoIndex = 0;
        window.openLightbox = (i) => {
            currentPhotoIndex = i; updateLightbox();
            document.getElementById('lightbox').classList.remove('hidden');
            document.getElementById('lightbox').classList.add('flex');
            document.body.style.overflow = 'hidden';
        };
        window.closeLightbox = () => {
            document.getElementById('lightbox').classList.add('hidden');
            document.body.style.overflow = 'auto';
        };
        window.nextPhoto = () => { currentPhotoIndex = (currentPhotoIndex + 1) % galleryImages.length; updateLightbox(); };
        window.prevPhoto = () => { currentPhotoIndex = (currentPhotoIndex - 1 + galleryImages.length) % galleryImages.length; updateLightbox(); };
        function updateLightbox() {
            document.getElementById('lightbox-img').src = galleryImages[currentPhotoIndex];
            document.getElementById('lightbox-counter').innerText = `IMAGEN ${currentPhotoIndex + 1} DE ${galleryImages.length}`;
        }

        // --- CALENDARIO (Lógica Integrada para Tropa, OA y Distrito) ---
        const themes = {
            purpura: { b: 'border-indigo-600', bg: 'bg-indigo-600', tb: 'bg-indigo-50', tc: 'text-indigo-600' },
            naranja: { b: 'border-orange-500', bg: 'bg-orange-500', tb: 'bg-orange-50', tc: 'text-orange-600' },
            verde: { b: 'border-green-600', bg: 'bg-green-600', tb: 'bg-green-50', tc: 'text-green-600' },
            azul: { b: 'border-blue-600', bg: 'bg-blue-600', tb: 'bg-blue-50', tc: 'text-blue-600' },
            rojo: { b: 'border-red-600', bg: 'bg-red-600', tb: 'bg-red-50', tc: 'text-red-600' }
        };

        const calIds = {
            tropa: "troop808pr%40gmail.com",
            oa: "7803ec765a89e88d9dc72ef1a267b6d4e1b75a32c4cf00820af8bffb5bac2d6f%40group.calendar.google.com",
            distrito: "887a472df723b4721b7c9f23649439b2b73bc64a94eb40d4c1e776df955977ba%40group.calendar.google.com"
        };

        // Variables Globales para el nuevo calendario FullCalendar
        let globalRawEvents = [];
        let calendarInstance = null;

        async function fetchEvents() {
            // Cambiamos caché a v10 para purgar memorias de horas anteriores
            const cachedData = localStorage.getItem('tropa808_v10_events');
            const cacheTime = localStorage.getItem('tropa808_v10_events_time');
            const now = new Date().getTime();
            const todayComp = new Date().setHours(0,0,0,0); 
            
            if (cachedData) {
                globalRawEvents = JSON.parse(cachedData);
                processAndRender(todayComp);
                if (cacheTime && (now - parseInt(cacheTime) < 7200000)) return; 
            }
            
            const calendars = [
                { id: calIds.tropa, source: 'tropa' },
                { id: calIds.oa, source: 'oa' },
                { id: calIds.distrito, source: 'distrito' }
            ];

            try {
                const promises = calendars.map(async (cal) => {
                    const iCalUrl = `https://calendar.google.com/calendar/ical/${cal.id}/public/basic.ics?v=${now}`;
                    // Proxies con forzado de no-cache para asegurar que descargue los horarios actualizados
                    const proxies = [
                        `https://api.allorigins.win/raw?url=${encodeURIComponent(iCalUrl)}&nocache=${now}`,
                        `https://corsproxy.io/?${encodeURIComponent(iCalUrl)}`,
                        `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(iCalUrl)}`
                    ];
                    
                    let rawICal = null;
                    try {
                        rawICal = await Promise.any(proxies.map(async p => {
                            const res = await fetch(p);
                            if (!res.ok) throw new Error();
                            const text = await res.text();
                            if (!text.includes("BEGIN:VCALENDAR")) throw new Error();
                            return text;
                        }));
                    } catch (error) {}

                    if (rawICal) {
                        // Unificar líneas cortadas por el formato ICS
                        const unfolded = rawICal.replace(/\r?\n[ \t]/g, "");
                        const vevents = unfolded.split('BEGIN:VEVENT').slice(1);
                        
                        return vevents.map(v => {
                            const s = v.match(/SUMMARY:(.*)/);
                            const stMatch = v.match(/DTSTART(?:;[^:]*)?:([0-9]{8}(?:T[0-9]{6}Z?)?)/);
                            const endMatch = v.match(/DTEND(?:;[^:]*)?:([0-9]{8}(?:T[0-9]{6}Z?)?)/);
                            const locMatch = v.match(/LOCATION:(.*)/);
                            const descMatch = v.match(/DESCRIPTION:(.*)/);

                            if (!stMatch) return null;

                            const dateStr = stMatch[1]; 
                            let eventDate, endDate = null;
                            
                            // Formateador ISO sin zona horaria para forzar la hora local en FullCalendar
                            const pad = n => String(n).padStart(2, '0');
                            const formatLocalISO = (d) => {
                                return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}:00`;
                            };

                            // Convertidor maestro: Convierte todo forzosamente a reloj de Puerto Rico
                            const parseIcsDateForPR = (str) => {
                                if (!str.includes('T')) {
                                    const y = parseInt(str.substring(0, 4), 10), m = parseInt(str.substring(4, 6), 10) - 1, d = parseInt(str.substring(6, 8), 10);
                                    return new Date(y, m, d);
                                }
                                const isUTC = str.endsWith('Z');
                                let y = parseInt(str.substring(0, 4), 10), m = parseInt(str.substring(4, 6), 10) - 1, d = parseInt(str.substring(6, 8), 10);
                                let h = parseInt(str.substring(9, 11), 10), min = parseInt(str.substring(11, 13), 10);
                                
                                if (isUTC) {
                                    const dObj = new Date(Date.UTC(y, m, d, h, min, 0));
                                    const prTimeMs = dObj.getTime() - (4 * 60 * 60 * 1000); // Restar 4 horas para PR
                                    const prDate = new Date(prTimeMs);
                                    // Extraemos las horas corregidas
                                    return new Date(prDate.getUTCFullYear(), prDate.getUTCMonth(), prDate.getUTCDate(), prDate.getUTCHours(), prDate.getUTCMinutes(), 0);
                                } else {
                                    return new Date(y, m, d, h, min, 0); // Asume que ya viene en PR
                                }
                            };

                            eventDate = parseIcsDateForPR(dateStr);
                            if (endMatch) {
                                endDate = parseIcsDateForPR(endMatch[1]);
                            }

                            // Textos de fecha listos para el Grid de FullCalendar
                            let startStr, endStr = null;
                            if (!dateStr.includes('T')) {
                                startStr = `${dateStr.substring(0, 4)}-${dateStr.substring(4, 6)}-${dateStr.substring(6, 8)}`;
                            } else {
                                startStr = formatLocalISO(eventDate);
                            }
                            
                            if (endDate && endMatch) {
                                if (!endMatch[1].includes('T')) {
                                    endStr = `${endMatch[1].substring(0, 4)}-${endMatch[1].substring(4, 6)}-${endMatch[1].substring(6, 8)}`;
                                } else {
                                    endStr = formatLocalISO(endDate);
                                }
                            }

                            // Colores para el calendario FullCalendar (Mantiene identidad)
                            let calBgColor = '#4c1d95'; // Purpura por defecto (Tropa)
                            const summaryLower = s ? s[1].toLowerCase() : "";
                            
                            if (cal.source === 'oa') calBgColor = '#dc2626'; // Rojo
                            else if (cal.source === 'distrito') calBgColor = '#2563eb'; // Azul
                            else {
                                if (summaryLower.includes('verde')) calBgColor = '#16a34a'; // Verde
                                else if (summaryLower.includes('naranja')) calBgColor = '#ea580c'; // Naranja
                                else if (summaryLower.includes('azul')) calBgColor = '#2563eb'; // Azul
                                else if (summaryLower.includes('rojo') || summaryLower.includes('roja')) calBgColor = '#dc2626'; // Rojo
                            }

                            // Limpiar descripción de códigos extraños de iCal
                            let cleanDesc = descMatch ? descMatch[1].trim() : "";
                            cleanDesc = cleanDesc.replace(/\\n/g, '<br>').replace(/\\,/g, ',').replace(/\\;/g, ';');

                            return { 
                                title: s ? s[1].trim() : "Evento", 
                                source: cal.source,
                                start: startStr, 
                                end: endStr,
                                allDay: !dateStr.includes('T'),
                                y: eventDate.getFullYear(), m: eventDate.getMonth(), d: eventDate.getDate(), 
                                comp: eventDate.getTime(),
                                backgroundColor: calBgColor,
                                borderColor: 'transparent',
                                extendedProps: {
                                    location: locMatch ? locMatch[1].trim() : "",
                                    description: cleanDesc
                                }
                            };
                        }).filter(e => e !== null);
                    }
                    return [];
                });

                const results = await Promise.all(promises);
                globalRawEvents = results.flat().sort((a,b) => a.comp - b.comp);

                if (globalRawEvents.length > 0) {
                    localStorage.setItem('tropa808_v10_events', JSON.stringify(globalRawEvents));
                    localStorage.setItem('tropa808_v10_events_time', now.toString());
                    processAndRender(todayComp);
                } else if (!cachedData) {
                    const container1 = document.getElementById('event-cards-container');
                    if(container1) container1.innerHTML = '<div class="col-span-1 md:col-span-3 text-center text-slate-500 text-sm font-bold uppercase py-10">No hay eventos próximos programados.</div>';
                }
            } catch (error) {
                console.error("Error obteniendo calendarios:", error);
            }
        }

        // Centraliza la preparación de tarjetas y la creación del FullCalendar
        function processAndRender(todayComp) {
            // 1. Renderizar tarjetas (Solo eventos futuros)
            const futureEvents = globalRawEvents.filter(e => e.comp >= todayComp);
            const groupedEvents = [];
            futureEvents.forEach(ev => {
                const dateKey = `${ev.y}-${ev.m}-${ev.d}`;
                let group = groupedEvents.find(g => g.key === dateKey);
                if (!group) {
                    group = { key: dateKey, y: ev.y, m: ev.m, d: ev.d, comp: ev.comp, summaries: [] };
                    groupedEvents.push(group);
                }
                group.summaries.push({ text: ev.title, source: ev.source });
            });
            renderEventHTML(groupedEvents.slice(0, 3), 'event-cards-container'); 

            // 2. Renderizar FullCalendar
            if (!calendarInstance) {
                initFullCalendar();
            } else {
                calendarInstance.removeAllEventSources();
                calendarInstance.addEventSource(globalRawEvents);
            }
        }

        // Inicializador de FullCalendar (Alternativa 2)
        function initFullCalendar() {
            var calendarEl = document.getElementById('calendar-custom');
            if (!calendarEl) return;

            calendarInstance = new FullCalendar.Calendar(calendarEl, {
                timeZone: 'America/Puerto_Rico', // Obliga al calendario a procesar todo en hora de PR
                firstDay: 0, // 0 = Domingo, 1 = Lunes
                initialView: window.innerWidth < 768 ? 'listMonth' : 'dayGridMonth',
                locale: 'es',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,listMonth'
                },
                buttonText: { today: 'Hoy', month: 'Mes', list: 'Agenda' },
                events: globalRawEvents,
                height: 'auto',
                
                // NUEVO: Fuerza el formato de 12 horas (AM/PM) en las cajitas del calendario
                eventTimeFormat: {
                    hour: 'numeric',
                    minute: '2-digit',
                    omitZeroMinute: true, // Si es en punto (ej. 9:00) mostrará "9 AM" para verse más limpio
                    meridiem: 'short',
                    hour12: true
                },
                
                eventClick: function(info) {
                    // AQUÍ ESTÁ LA MAGIA: Interceptamos el click y abrimos nuestro propio Modal elegante
                    info.jsEvent.preventDefault();
                    
                    const ev = info.event;
                    
                    // Configurar Título y Color
                    document.getElementById('modal-title').innerText = ev.title;
                    document.getElementById('modal-color').style.backgroundColor = ev.backgroundColor;
                    
                    // Configurar Tag superior
                    let tagText = "Tropa 808";
                    if (ev.extendedProps.source === 'oa') tagText = "Order of the Arrow";
                    else if (ev.extendedProps.source === 'distrito') tagText = "Distrito Majagua";
                    document.getElementById('modal-tag').innerText = tagText;
                    
                    // Formatear Fecha con el motor exacto de FullCalendar
                    document.getElementById('modal-date').innerText = info.view.calendar.formatDate(ev.start, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                    
                    // Formatear Hora con el motor exacto de FullCalendar para evitar desfases
                    if (ev.allDay) {
                        document.getElementById('modal-time').innerText = "Todo el día";
                    } else {
                        const opts = { hour: 'numeric', minute: '2-digit', hour12: true };
                        let timeStr = info.view.calendar.formatDate(ev.start, opts);
                        if (ev.end) {
                            timeStr += " - " + info.view.calendar.formatDate(ev.end, opts);
                        }
                        // Limpiar formato para que diga AM/PM limpio y estético
                        timeStr = timeStr.replace(/a\.?\s*m\.?/gi, 'AM').replace(/p\.?\s*m\.?/gi, 'PM');
                        document.getElementById('modal-time').innerText = timeStr;
                    }
                    
                    // Configurar Lugar
                    const locContainer = document.getElementById('modal-location-container');
                    if (ev.extendedProps.location && ev.extendedProps.location.trim() !== "") {
                        document.getElementById('modal-location').innerText = ev.extendedProps.location;
                        locContainer.classList.remove('hidden');
                    } else {
                        locContainer.classList.add('hidden');
                    }
                    
                    // Configurar Descripción
                    const descContainer = document.getElementById('modal-desc-container');
                    if (ev.extendedProps.description && ev.extendedProps.description.trim() !== "") {
                        // Respetar enlaces (convertirlos en clickeables)
                        let descFormatted = ev.extendedProps.description.replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" class="text-indigo-600 font-bold hover:underline">$1</a>');
                        document.getElementById('modal-description').innerHTML = descFormatted;
                        descContainer.classList.remove('hidden');
                    } else {
                        descContainer.classList.add('hidden');
                    }
                    
                    // Mostrar el Modal
                    document.getElementById('event-modal').classList.remove('hidden');
                    // Retraso para la animación de entrada
                    setTimeout(() => { document.getElementById('event-modal').classList.remove('opacity-0'); }, 10);
                    document.body.style.overflow = 'hidden';
                }
            });
        }

        // Función para cerrar el modal de eventos
        window.closeEventModal = () => {
            document.getElementById('event-modal').classList.add('opacity-0');
            setTimeout(() => { 
                document.getElementById('event-modal').classList.add('hidden'); 
                document.body.style.overflow = 'auto';
            }, 300);
        };

        function renderEventHTML(events, targetId) {
            const container = document.getElementById(targetId);
            if(!container) return;
            
            const months = ["ENE", "FEB", "MAR", "ABR", "MAY", "JUN", "JUL", "AGO", "SEP", "OCT", "NOV", "DIC"];
            const allColors = ['purpura', 'naranja', 'verde', 'azul', 'rojo'];
            
            // Paso 1: Identificar colores explícitos primero para no repetirlos
            let usedColors = [];
            const processedEvents = events.map(ev => {
                const primaryEvent = ev.summaries[0]; 
                const sl = primaryEvent.text.toLowerCase();
                let explicitColor = null;

                if (primaryEvent.source === 'oa') explicitColor = 'rojo';
                else if (primaryEvent.source === 'distrito') explicitColor = 'azul';
                else {
                    if (sl.includes('verde')) explicitColor = 'verde';
                    else if (sl.includes('naranja')) explicitColor = 'naranja';
                    else if (sl.includes('azul')) explicitColor = 'azul';
                    else if (sl.includes('rojo') || sl.includes('roja')) explicitColor = 'rojo';
                    else if (sl.includes('purpura') || sl.includes('púrpura') || sl.includes('violeta')) explicitColor = 'purpura';
                }

                if (explicitColor) usedColors.push(explicitColor);
                return { ...ev, explicitColor, primaryEvent, sl };
            });

            // Paso 2: Generar HTML asegurando colores diferentes
            container.innerHTML = processedEvents.map((ev, i) => {
                let chosenKey = ev.explicitColor;

                // Si no tiene color explícito, buscar uno que no se haya usado en las otras tarjetas
                if (!chosenKey) {
                    chosenKey = allColors.find(color => !usedColors.includes(color));
                    if (!chosenKey) chosenKey = allColors[i % allColors.length]; // Respaldo extremo
                    usedColors.push(chosenKey); // Registrar para no repetirlo
                }
                
                const st = themes[chosenKey];
                
                let tag = "EVENTO";
                if (ev.summaries.length > 1) {
                    tag = "AGENDA MULTIPLE";
                } else {
                    if(ev.sl.includes("reunion") || ev.sl.includes("reunión")) tag = "REUNIÓN";
                    else if(ev.sl.includes("caminata")) tag = "CAMINATA";
                    else if(ev.sl.includes("camping") || ev.sl.includes("guajataka")) tag = "CAMPING";
                    else if(ev.primaryEvent.source === 'oa') tag = "ORDER OF THE ARROW";
                    else if(ev.primaryEvent.source === 'distrito') tag = "DISTRITO";
                }

                const textSize = ev.summaries.length > 1 ? 'text-lg md:text-xl' : 'text-2xl';
                const titlesHtml = ev.summaries.map(s => {
                    let badge = '';
                    if(s.source === 'oa') badge = '<span class="bg-red-100 text-red-700 text-[8px] px-2 py-0.5 rounded-md ml-2 font-bold tracking-widest border border-red-200 uppercase whitespace-nowrap">OA</span>';
                    else if(s.source === 'distrito') badge = '<span class="bg-blue-100 text-blue-700 text-[8px] px-2 py-0.5 rounded-md ml-2 font-bold tracking-widest border border-blue-200 uppercase whitespace-nowrap">Distrito</span>';
                    return `<div class="flex items-start mb-2"><h4 class="${textSize} font-brand text-indigo-950 leading-tight">${s.text}</h4>${badge}</div>`;
                }).join('<div class="w-12 h-px bg-slate-200 my-3"></div>');

                return `
                <div class="event-card-new bg-white rounded-3xl p-8 border-b-8 ${st.b} shadow-xl flex flex-col justify-between h-full">
                    <div>
                        <div class="flex items-center justify-between mb-8">
                            <div class="flex items-center">
                                <div class="${st.bg} text-white px-4 py-2 rounded-xl text-center shadow-md">
                                    <span class="block text-[10px] font-bold uppercase leading-tight">${months[ev.m]}</span>
                                    <span class="block text-2xl font-brand leading-none">${ev.d}</span>
                                </div>
                            </div>
                            <span class="${st.tb} ${st.tc} text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest text-right max-w-[50%] leading-tight">${tag}</span>
                        </div>
                        ${ev.summaries.length > 1 ? '<span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3 block">Múltiples eventos hoy:</span>' : ''}
                        ${titlesHtml}
                    </div>
                </div>`;
            }).join('');
        }

        window.filterCalendar = (type) => {
            const btnTodos = document.getElementById('btn-filtro-todos');
            const btnTropa = document.getElementById('btn-filtro-tropa');
            const btnOa = document.getElementById('btn-filtro-oa');
            const btnDistrito = document.getElementById('btn-filtro-distrito');

            // Reiniciar botones
            [btnTodos, btnTropa, btnOa, btnDistrito].forEach(btn => {
                btn.className = "bg-white border px-5 py-2.5 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest transition shadow-sm hover:scale-105 hover:opacity-80";
            });
            btnTodos.classList.add('text-indigo-900', 'border-indigo-200');
            btnTropa.classList.add('text-indigo-900', 'border-indigo-200');
            btnOa.classList.add('text-red-700', 'border-red-200');
            btnDistrito.classList.add('text-blue-700', 'border-blue-200');

            // Activar botón seleccionado
            let activeBtn;
            if(type === 'todos') { activeBtn = btnTodos; activeBtn.classList.remove('bg-white', 'text-indigo-900'); activeBtn.classList.add('bg-indigo-900', 'text-white'); }
            if(type === 'tropa') { activeBtn = btnTropa; activeBtn.classList.remove('bg-white', 'text-indigo-900'); activeBtn.classList.add('bg-indigo-900', 'text-white'); }
            if(type === 'oa') { activeBtn = btnOa; activeBtn.classList.remove('bg-white', 'text-red-700'); activeBtn.classList.add('bg-red-700', 'text-white'); }
            if(type === 'distrito') { activeBtn = btnDistrito; activeBtn.classList.remove('bg-white', 'text-blue-700'); activeBtn.classList.add('bg-blue-700', 'text-white'); }
            
            activeBtn.classList.add('shadow-md');

            // NUEVO: Filtrar eventos del FullCalendar al instante
            if (calendarInstance) {
                let filteredEvents = globalRawEvents;
                if (type !== 'todos') {
                    filteredEvents = globalRawEvents.filter(e => e.source === type);
                }
                calendarInstance.removeAllEventSources();
                calendarInstance.addEventSource(filteredEvents);
            }

            // --- LÓGICA DE SINCRONIZACIÓN DINÁMICA ---
            const syncBtnGoogle = document.getElementById('sync-btn-google');
            const syncBtnApple = document.getElementById('sync-btn-apple');
            const syncTitle = document.getElementById('sync-title');
            const syncWarningTodos = document.getElementById('sync-warning-todos');
            const syncButtonsContainer = document.getElementById('sync-buttons-container');

            const calIdsEncoded = {
                tropa: "troop808pr%40gmail.com",
                oa: "7803ec765a89e88d9dc72ef1a267b6d4e1b75a32c4cf00820af8bffb5bac2d6f%40group.calendar.google.com",
                distrito: "887a472df723b4721b7c9f23649439b2b73bc64a94eb40d4c1e776df955977ba%40group.calendar.google.com"
            };

            let selectedCalId = type === 'todos' ? calIdsEncoded.tropa : calIdsEncoded[type];

            // Actualizar enlaces de los botones de descarga
            if (syncBtnGoogle && syncBtnApple) {
                syncBtnGoogle.href = `https://calendar.google.com/calendar/r?cid=${selectedCalId}`;
                syncBtnApple.href = `webcal://calendar.google.com/calendar/ical/${selectedCalId}/public/basic.ics`;
            }

            // Actualizar textos y visibilidad de los botones/advertencia
            if (type === 'todos') {
                if (syncTitle) syncTitle.innerHTML = `<i class="fas fa-sync-alt mr-2 text-indigo-600"></i> Sincroniza tu Agenda`;
                if (syncButtonsContainer) syncButtonsContainer.classList.add('hidden');
                if (syncWarningTodos) syncWarningTodos.classList.remove('hidden');
            } else {
                if (syncButtonsContainer) syncButtonsContainer.classList.remove('hidden');
                if (syncWarningTodos) syncWarningTodos.classList.add('hidden');

                if (syncTitle) {
                    if (type === 'tropa') {
                        syncTitle.innerHTML = `<i class="fas fa-sync-alt mr-2 text-indigo-600"></i> Sincroniza Tropa 808`;
                    } else if (type === 'oa') {
                        syncTitle.innerHTML = `<i class="fas fa-sync-alt mr-2 text-red-600"></i> Sincroniza O.A.`;
                    } else if (type === 'distrito') {
                        syncTitle.innerHTML = `<i class="fas fa-sync-alt mr-2 text-blue-600"></i> Sincroniza Distrito`;
                    }
                }
            }
        };

        document.getElementById('toggle-calendar').onclick = () => {
            const googleCal = document.getElementById('google-calendar-section');
            const eventCards = document.getElementById('event-cards-container');
            const toggleText = document.getElementById('toggle-text');
            
            // Alternar visibilidad de ambos contenedores
            googleCal.classList.toggle('hidden');
            eventCards.classList.toggle('hidden');
            
            // Cambiar texto y forzar renderizado de FullCalendar
            if (!googleCal.classList.contains('hidden')) {
                toggleText.innerText = "Ver próximos eventos";
                if (calendarInstance) {
                    setTimeout(() => { calendarInstance.render(); }, 10);
                }
            } else {
                toggleText.innerText = "Ver calendario completo";
            }
        };

        // --- LÓGICA PARA VER MÁS RELATOS ---
        function initRelatos() {
            const grid = document.getElementById('relatos-grid');
            if (!grid) return;
            const articles = grid.querySelectorAll('article');
            const btnContainer = document.getElementById('ver-mas-container');
            
            if (articles.length > 3) {
                for (let i = 3; i < articles.length; i++) {
                    articles[i].classList.add('hidden', 'relato-extra');
                }
                if(btnContainer) btnContainer.classList.remove('hidden');
            } else {
                if(btnContainer) btnContainer.classList.add('hidden');
            }
        }

        window.toggleRelatos = () => {
            const extras = document.querySelectorAll('.relato-extra');
            const btn = document.getElementById('btn-ver-mas');
            let isExpanded = false;

            extras.forEach(el => {
                if (el.classList.contains('hidden')) {
                    el.classList.remove('hidden');
                    isExpanded = true;
                } else {
                    el.classList.add('hidden');
                }
            });

            if (isExpanded) {
                btn.innerHTML = 'Ver menos relatos <i class="fas fa-chevron-up ml-2"></i>';
            } else {
                btn.innerHTML = 'Ver más relatos <i class="fas fa-chevron-down ml-2"></i>';
                setTimeout(() => {
                    document.getElementById('blog').scrollIntoView({behavior: 'smooth', block: 'start'});
                }, 100);
            }
        };

        window.onload = () => { 
            fetchEvents(); 
            initRelatos(); 
            
            if (window.location.hash === '#recursos') {
                switchView('docs');
            } else if (window.location.hash === '#insignia') {
                switchView('insignia');
            }
        };
    </script>
</body>
</html>
